# === HYPERSPACE DB CONFIGURATION ===

# --- Server Dimensions & Metric ---
# Use 'poincare', 'l2', 'cosine' and 'lorentz' as metric
HS_DIMENSION=1024
HS_METRIC=cosine

# Option 2: Scientific / Native Hyperbolic
# Use 'poincare' for maximum efficiency on compressed hyperbolic vectors.
# HS_DIMENSION=64
# HS_METRIC=poincare

# --- HNSW Engine Tuning ---
# --- Metrics #1 ---
# Database        | Dim   | Metric   | Ins QPS  | Srch QPS | P99 Lat    | Recall(Sys) | MRR   | NDCG  | C1     | C10    | C30    |
# --------------------------------------------------------------------------------------------------------------------------------
# Hyperspace      | 1024  | Cosine   |    24542 |     1036 |    1.73 ms |       89.8% |  1.00 |  0.92 |   1205 |   2931 |   2753 |
# Hyperspace      | 64    | Poincare |   157950 |     2912 |    0.88 ms |       99.8% |  1.00 |  0.92 |   4893 |   2784 |   2326 |
# HS_HNSW_M=48
# HS_HNSW_EF_CONSTRUCT=200
# HS_HNSW_EF_SEARCH=200

# --- HNSW Engine Tuning ---
# --- Metrics #2 ---
# Database        | Dim   | Metric   | Ins QPS  | Srch QPS | P99 Lat    | Recall(Sys) | MRR   | NDCG  | C1     | C10    | C30    |
# --------------------------------------------------------------------------------------------------------------------------------
# Hyperspace      | 1024  | Cosine   |    23662 |      995 |    2.36 ms |       99.8% |  1.00 |  0.92 |   1146 |   2761 |   2473 |
# Hyperspace      | 64    | Poincare |   158675 |     2777 |    1.52 ms |       99.9% |  1.00 |  0.92 |   4577 |   2725 |   2401 |
HS_HNSW_M=64
HS_HNSW_EF_CONSTRUCT=400
HS_HNSW_EF_SEARCH=400
# If filtered candidate set is small, bypass HNSW layer-0 traversal and run exact brute-force over allowed bitmap.
HS_FILTER_BRUTEFORCE_THRESHOLD=50000

# --- Durability & Safety ---
# Options: async (default), batch (100ms lag), strict (fsync every write)
# Controls the trade-off between write speed and data safety.
HYPERSPACE_WAL_SYNC_MODE=batch
# Interval for Batch mode in milliseconds
HYPERSPACE_WAL_BATCH_INTERVAL=100
# WAL segment size in MB. When the active WAL reaches this size, it is frozen
# and a background worker builds a new immutable chunk (chunk_*.hyp).
# Larger = fewer flushes, lower CPU overhead on RAM-rich servers.
# Smaller = more frequent rotations, better for RAM-constrained / S3-tiered deployments.
# Range: 16..4096 MB. Default: 512 MB (optimized for performance).
HS_WAL_SEGMENT_SIZE_MB=512

# --- Performance & Resource Management ---
# Storage Mode: performance (default, server) or tiered (LSM-style, edge)
# performance: All data in RAM, snapshots for persistence. Maximum performance.
# tiered: Flushes to disk chunks when MemTable exceeds memory budget. For edge devices.
HS_MODE=performance
# Max RAM budget for the in-memory index in GB.
# If not set, defaults to 70% of total system RAM.
HS_MAX_RAM_GB=44

# Number of parallel threads for HNSW graph construction
# 1 = Serial (best quality/recall, slower indexing)
# 0 = Auto (uses all CPU cores, faster but lower recall due to race conditions)
# Recommended: 1 for production, 0 for bulk imports where recall can be sacrificed
HS_INDEXER_CONCURRENCY=8

# --- Storage & Quantization ---
# Options: none, scalar (i8), binary (1 bit)
# Note: Scalar quantization clamps values to [-1, 1]. Use 'none' for unbounded L2 vectors if you care about magnitude > 1.
HS_QUANTIZATION_LEVEL=scalar
# Enable ScaNN-style anisotropic refinement for 8-bit quantization.
# Improves recall and ranking quality (especially for Cosine/L2) but adds CPU overhead during indexing.
# Set to 'false' for maximum raw ingestion speed.
HS_ANISOTROPIC_REFINEMENT=false
# Store raw (mode=none) vectors as f32 in mmap, then promote to f64 in distance kernel. Saves ~50% RAM for raw vectors.
HS_STORAGE_FLOAT32=true
# Fast-upsert threshold: if vector shift L2 <= delta and metadata unchanged, skip graph relinking.
# 0.0 disables fast-upsert (always relink graph).
# Typical values: 0.001..0.05 for small continuous updates; >0.1 may preserve stale neighborhood links.
HS_FAST_UPSERT_DELTA=0.0
# ID Mapping bypass: set to 'true' if user IDs always match internal IDs (no upserts).
# Skips DashMap lookups on insert/search, reducing latency by ~10%.
# WARNING: Only enable if you never upsert (update) existing vectors.
HS_IDENTITY_IDS=false
# Broadcast ring size for CDC/replication event stream.
HS_EVENT_STREAM_BUFFER=1024
# Enable exact top-K re-rank after ANN candidate fetch.
HS_RERANK_ENABLED=true
# Oversample factor for ANN candidates before exact re-rank.
HS_RERANK_OVERSAMPLE=8
# Enable runtime auto-dispatch policy for batch metric kernels.
HS_GPU_BATCH_ENABLED=false
# Conservative offload thresholds to avoid GPU regression on tiny rerank batches.
HS_GPU_MIN_BATCH=192
HS_GPU_MIN_DIM=1024
HS_GPU_MIN_WORK=393216
# Per-metric GPU dispatch toggles (effective only when HS_GPU_BATCH_ENABLED=true and build uses --features gpu-runtime).
HS_GPU_L2_ENABLED=true
HS_GPU_COSINE_ENABLED=true
HS_GPU_POINCARE_ENABLED=true
HS_GPU_LORENTZ_ENABLED=true
# Internal fan-out for SearchBatch handler (1 = deterministic/serial, >1 = bounded parallel).
HS_SEARCH_BATCH_INNER_CONCURRENCY=32
# Global limit for concurrent search tasks in collection worker pool.
# 0 = auto (CPU count * 2), recommended range: CPU..(CPU*4) depending on latency SLA.
# Auto mode provides optimal throughput: 2x cores for parallelism, capped at 4x to avoid thrashing.
HS_SEARCH_CONCURRENCY=0

# --- Graph Optimization (Compaction) ---
# Automatic graph rebuild interval in hours (0 = disabled)
# Rebuilds the HNSW graph sequentially for maximum quality
# Recommended: 24-48 hours for production systems with high write load
# Set to 0 to disable automatic optimization
HS_OPTIMIZE_INTERVAL_HOURS=0


# --- Security ---
HYPERSPACE_API_KEY=I_LOVE_HYPERSPACEDB

# === EMBEDDING PIPELINE CONFIGURATION ===
# Provide vectors automatically (InsertText / SearchText RPC).
# Embedding is DISABLED by default — set to 'true' to enable.
HYPERSPACE_EMBED=false

# ─────────────────────────────────────────────────────────────────────────────
# Per-Metric Embedding Architecture
# ─────────────────────────────────────────────────────────────────────────────
# HyperspaceDB supports 4 geometry types: l2, cosine, poincare, lorentz
# Each geometry can have its own embedding backend independently:
#
#   HS_EMBED_<METRIC>_PROVIDER — one of:
#     local        → local ONNX file (fastest, no network)
#     huggingface  → download model.onnx + tokenizer.json from HF Hub
#     openai       → OpenAI Embeddings API
#     cohere       → Cohere Embed API
#     mistral      → Mistral Embeddings API
#     voyage       → Voyage AI API
#     openrouter   → OpenRouter API
#     generic      → Any OpenAI-compatible API (set HS_EMBED_<METRIC>_API_BASE)
#     disabled     → No embedding for this metric (default)
#
# If HS_EMBED_<METRIC>_PROVIDER is not set, falls back to HYPERSPACE_EMBED_PROVIDER.
# ─────────────────────────────────────────────────────────────────────────────

# --- Global Embedding Fallback ---
# Used if no per-metric provider is configured.
# HYPERSPACE_EMBED_PROVIDER=disabled

# --- Hugging Face Token (applies to ALL huggingface providers) ---
# Required for gated/private models, optional for public ones.
# Can also be set via env: HUGGING_FACE_HUB_TOKEN (same effect)
# HF_TOKEN=hf_your_token_here

# ─────────────────────────────────────────────────────────────────────────────
# L2 (Euclidean) Geometry Embedding
# ─────────────────────────────────────────────────────────────────────────────
# HS_EMBED_L2_PROVIDER=disabled

# Option A: Local ONNX
# HS_EMBED_L2_MODEL_PATH=./models/bge-small-en-v1.5.onnx
# HS_EMBED_L2_TOKENIZER_PATH=./models/bge-small-en-v1.5-tokenizer.json
# HS_EMBED_L2_DIM=384

# Option B: HuggingFace Hub (auto-downloads model.onnx + tokenizer.json)
# HS_EMBED_L2_PROVIDER=huggingface
# HS_EMBED_L2_HF_MODEL_ID=BAAI/bge-small-en-v1.5
# HS_EMBED_L2_DIM=384

# Option C: Remote API
# HS_EMBED_L2_PROVIDER=openai
# HS_EMBED_L2_EMBED_MODEL=text-embedding-3-small
# HS_EMBED_L2_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# NEW: Qwen3-Embedding-0.6B (Supports L2 & Cosine)
# Context: 32K tokens | Max Dimension: 1024d
# https://huggingface.co/Qwen/Qwen3-Embedding-0.6B
# ─────────────────────────────────────────────────────────────────────────────
# L2 Configuration
HS_EMBED_L2_PROVIDER=huggingface
HS_EMBED_L2_HF_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
HS_EMBED_L2_DIM=1024
# Chunking for 32K context (use smaller chunks for efficiency)
HS_EMBED_L2_CHUNK_SIZE=4096
HS_EMBED_L2_OVERLAP=0.10  # 10% overlap between chunks

# ─────────────────────────────────────────────────────────────────────────────
# Cosine Geometry Embedding
# ─────────────────────────────────────────────────────────────────────────────
# See Qwen3-Embedding-0.6B configuration above (HS_EMBED_COSINE_*)
#
# Alternative configurations (commented out):
# ─────────────────────────────────────────────────────────────────────────────
# HS_EMBED_COSINE_PROVIDER=disabled

# Option A: Local ONNX
# HS_EMBED_COSINE_MODEL_PATH=./models/e5-large-v2.onnx
# HS_EMBED_COSINE_TOKENIZER_PATH=./models/e5-large-v2-tokenizer.json
# HS_EMBED_COSINE_DIM=1024

# Cosine Configuration (same model, different normalization)
HS_EMBED_COSINE_PROVIDER=huggingface
HS_EMBED_COSINE_HF_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
HS_EMBED_COSINE_DIM=1024
HS_EMBED_COSINE_CHUNK_SIZE=4096
HS_EMBED_COSINE_OVERLAP=0.10  # 10% overlap between chunks

# Option C: Remote API
# HS_EMBED_COSINE_PROVIDER=openai
# HS_EMBED_COSINE_EMBED_MODEL=text-embedding-3-large
# HS_EMBED_COSINE_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Poincaré Geometry Embedding
# Best for hierarchical / tree-like data (ontologies, taxonomies, KB graphs)
# Vectors must lie inside the unit ball: ||x|| < 1
# ─────────────────────────────────────────────────────────────────────────────
# HS_EMBED_POINCARE_PROVIDER=disabled

# Option A: Local ONNX (recommended — hyperbolic models are rare on hosted APIs)
# HS_EMBED_POINCARE_MODEL_PATH=./models/poincare_128d.onnx
# HS_EMBED_POINCARE_TOKENIZER_PATH=./models/poincare_128d_tokenizer.json
# HS_EMBED_POINCARE_DIM=128

# Option B: HuggingFace Hub (CDE-Spatial or custom hyperbolic model)
# NEW: YARlabs v5_Embedding_0.5B with chunking support (512 tokens context)
HS_EMBED_POINCARE_PROVIDER=huggingface
HS_EMBED_POINCARE_HF_MODEL_ID=YARlabs/v5_Embedding_0.5B
HS_EMBED_POINCARE_DIM=128
# Chunking configuration for 512 token context window
HS_EMBED_POINCARE_CHUNK_SIZE=512
HS_EMBED_POINCARE_OVERLAP=0.15  # 15% overlap between chunks

# Option C: Remote API (generic OpenAI-compatible endpoint serving hyperbolic embeddings)
# HS_EMBED_POINCARE_PROVIDER=generic
# HS_EMBED_POINCARE_API_BASE=http://localhost:8080/v1/embeddings
# HS_EMBED_POINCARE_API_KEY=local-key

# ─────────────────────────────────────────────────────────────────────────────
# Lorentz Geometry Embedding
# Best for mixed hierarchical + semantic data (knowledge graphs, multimodal)
# Vectors lie on the Lorentz hyperboloid: -x₀² + x₁²+...+xₙ² = -1
# ─────────────────────────────────────────────────────────────────────────────
# HS_EMBED_LORENTZ_PROVIDER=disabled

# Option A: Local ONNX
# HS_EMBED_LORENTZ_MODEL_PATH=./models/lorentz_128d.onnx
# HS_EMBED_LORENTZ_TOKENIZER_PATH=./models/lorentz_128d_tokenizer.json
# HS_EMBED_LORENTZ_DIM=129   # Note: Lorentz dim = Euclidean_dim + 1 (time component)

# Option B: HuggingFace Hub (CDE-Spatial v1/v2 models)
# NEW: YARlabs v5_Embedding_0.5B with chunking support (512 tokens context)
HS_EMBED_LORENTZ_PROVIDER=huggingface
HS_EMBED_LORENTZ_HF_MODEL_ID=YARlabs/v5_Embedding_0.5B
HS_EMBED_LORENTZ_DIM=128
# Chunking configuration for 512 token context window
HS_EMBED_LORENTZ_CHUNK_SIZE=512
HS_EMBED_LORENTZ_OVERLAP=0.15  # 15% overlap between chunks

# Option C: Remote API
# HS_EMBED_LORENTZ_PROVIDER=generic
# HS_EMBED_LORENTZ_API_BASE=http://localhost:8080/v1/embeddings
# HS_EMBED_LORENTZ_API_KEY=local-key

# ─────────────────────────────────────────────────────────────────────────────
# Legacy / Global Config (kept for backwards compatibility)
# These are used as fallback if per-metric keys are not set.
# ─────────────────────────────────────────────────────────────────────────────
# HYPERSPACE_MODEL_PATH=./models/v5_Embedding_128d.onnx
# HYPERSPACE_TOKENIZER_PATH=./models/v5_Embedding_Tokenizer.json
# HYPERSPACE_EMBED_DIM=128
# HYPERSPACE_HF_MODEL_ID=your-org/model-id
# HYPERSPACE_EMBED_MODEL=text-embedding-3-small
# HYPERSPACE_API_BASE=http://localhost:8080/v1/embeddings
# HYPERSPACE_API_KEY_EMBED=sk-...

# --- System Tuning ---
# Jemalloc configuration for memory usage vs CPU trade-off.
# background_thread:true enables background memory reclamation.
# dirty_decay_ms:0 releases unused memory immediately (low RAM, higher CPU).
# dirty_decay_ms:10000 (default) keeps memory for reuse (high RAM, lower CPU).
MALLOC_CONF=background_thread:true,dirty_decay_ms:5000,muzzy_decay_ms:5000

# ═══════════════════════════════════════════════════════════════════════════
# S3 Tiering (OPTIONAL — requires cargo build --features s3-tiering)
# ═══════════════════════════════════════════════════════════════════════════

# Storage backend: "local" (default) or "s3"
# "local" — all chunks stay on local NVMe/SSD. Best for edge & performance.
# "s3"    — cold chunks are offloaded to S3/MinIO with local LRU cache.
HS_STORAGE_BACKEND=local

# S3 bucket for chunk storage
# HS_S3_BUCKET=hyperspace-chunks

# AWS region
# HS_S3_REGION=us-east-1

# S3-compatible endpoint (for MinIO, Ceph, LocalStack)
# HS_S3_ENDPOINT=http://localhost:9000

# AWS/MinIO credentials
# HS_S3_ACCESS_KEY=minioadmin
# HS_S3_SECRET_KEY=minioadmin

# Object key prefix inside the bucket
# HS_S3_PREFIX=v1/chunks

# Local LRU cache size limit in GB (S3 mode only)
# When exceeded, oldest chunks are evicted to S3 and removed from disk.
# HS_MAX_LOCAL_CACHE_GB=10

# Max retry attempts for transient S3 errors (network interruptions)
# Uses exponential backoff: 100ms, 200ms, 400ms, ...
# HS_S3_MAX_RETRIES=3

# Parallel S3 upload/download slots (semaphore-limited)
# HS_S3_UPLOAD_CONCURRENCY=4

# Number of chunks to probe per search query (MetaRouter)
# Higher = better recall, lower = faster search. Default: 3.
HS_CHUNK_PROBE_K=3

# ═══════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════

# --- Gossip & Anti-Entropy (Clustering) ---
# Set to 'true' to enable decentralized cluster discovery (UDP Heartbeats) and Merkle Tree synchronization.
# CRITICAL PERFORMANCE NOTE: When enabled, every insert/delete triggers a FNV-1a bucket hash update.
# Keep as 'false' for maximum standalone performance unless you are running a multi-node cluster.
HS_GOSSIP_ENABLED=false

# Port for the UDP Heartbeat listener (default 7946)
HS_GOSSIP_PORT=7946

# Comma-separated list of known peers to bootstrap the swarm
# Example: 192.168.1.10:7946,192.168.1.11:7946
HS_GOSSIP_PEERS=
